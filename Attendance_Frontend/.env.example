# Backend API URL (use /api/v1 for local dev + Vite proxy, or for Vercel proxy)
# Local: /api/v1 (Vite proxies to localhost:8000) | Vercel: /api/v1 or unset (proxies to Render)
VITE_API_URL=/api/v1

# Supabase (for Realtime - copy from project root .env)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
