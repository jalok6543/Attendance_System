# Application
APP_NAME=Attendance Tracking System
SCHOOL_NAME=XYZ School
AUTO_LOW_ATTENDANCE_ALERTS=true
DEBUG=false
ENVIRONMENT=development

# API (Render: use SECRET_KEY or JWT_SECRET)
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Supabase (required)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Fast2SMS (SMS Alerts - optional)
# Get API key from https://www.fast2sms.com
FAST2SMS_API_KEY=

# ML - buffalo_l for best accuracy (needs ~1GB RAM); buffalo_s for 512MB
INSIGHTFACE_MODEL=buffalo_l
PRELOAD_ML_ENGINES=false
DET_SIZE=960
FACE_RECOGNITION_THRESHOLD=0.55
FACE_RECOGNITION_THRESHOLD_REALTIME=0.70
ENROLLMENT_DUPLICATE_THRESHOLD=0.75
MAX_FACES_DETECT=3
DETECTION_SCORE_MIN=0.6
MIN_BLUR_VARIANCE=100.0
REALTIME_DET_SIZE=640
REALTIME_DET_THRESH=0.5
EMBEDDING_CACHE_REFRESH_SEC=300

# CORS (Render: add your Vercel URL, e.g. https://your-app.vercel.app)
# *.vercel.app is allowed automatically
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
